# BSC Sniper Bot — Environment Configuration
# Copy this to .env and fill in your values

# BSC RPC Endpoint
RPC_URL=https://bsc-dataseed1.binance.org

# Your wallet private key
# WARNING: Never share this. Use a dedicated wallet.
TRADER_PRIVATE_KEY=

# Snipe settings
TRADE_SIZE_BNB=0.001
MAX_SNIPES=5
PROFIT_TARGET=2.0

# Safe mode: true = estimate only
DRY_RUN=true
